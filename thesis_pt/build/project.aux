\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces  Arquitetura da rede DG-CA3. Sinapses inibitórias são representadas por círculos e excitatórias por flechas. A entrada da rede é composta pelas células do córtex entorrinal (EC, \textit  {Entorhinal Cortex}). O giro dentado (DG, \textit  {Dentate Gyrus}) possui na camada molecular a via perfurante (PP, \textit  {Perforant Path}) e os dendritos de suas células; a camada granular é composta pelas células granulares jovens e maduras (iGCs e mGCs, respectivamente, \textit  {immature and mature Granule Cells}) e pelas células em cesto (BC, \textit  {Basket Cells}); o hilo é composto pelas células musgosas (MC, \textit  {Mossy Cells}) e pelas células inibitórias do hilo associadas à PP (HIPP, \textit  {HIlar Perforant Path-associated}). O CA3 é composto pelas células piramidais (PCA3, \textit  {Pyramidal Cells of the CA3}) e pelas células inibitórias (ICA3, \textit  {Interneurons of the CA3}).}}{17}{figure.caption.8}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:arquitetura-rede}{{1}{17}{Arquitetura da rede DG-CA3. Sinapses inibitórias são representadas por círculos e excitatórias por flechas. A entrada da rede é composta pelas células do córtex entorrinal (EC, \textit {Entorhinal Cortex}). O giro dentado (DG, \textit {Dentate Gyrus}) possui na camada molecular a via perfurante (PP, \textit {Perforant Path}) e os dendritos de suas células; a camada granular é composta pelas células granulares jovens e maduras (iGCs e mGCs, respectivamente, \textit {immature and mature Granule Cells}) e pelas células em cesto (BC, \textit {Basket Cells}); o hilo é composto pelas células musgosas (MC, \textit {Mossy Cells}) e pelas células inibitórias do hilo associadas à PP (HIPP, \textit {HIlar Perforant Path-associated}). O CA3 é composto pelas células piramidais (PCA3, \textit {Pyramidal Cells of the CA3}) e pelas células inibitórias (ICA3, \textit {Interneurons of the CA3})}{figure.caption.8}{}}
\newlabel{fig:arquitetura-rede@cref}{{[figure][1][]1}{[1][16][]17}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Grafo em anel da rede DG-CA3. Cada nó representa um neurônio do modelo, com o mesmo esquema de cores da Figura~\ref {fig:arquitetura-rede} para cada neurônio. Cada aresta representa uma sinapse, representada pela cor do neurônio pré-sináptico. O EC é representado pelo círculo mais externo em preto, é possível ver a organização lamelar do DG com as mGCs e iGCs (vermelho e rosa, respectivamente) e as PCA3s no centro em turquesa. No total, o grafo possui 3.260 nós e 266.596 arestas.}}{18}{figure.caption.9}\protected@file@percent }
\newlabel{fig:graph}{{2}{18}{Grafo em anel da rede DG-CA3. Cada nó representa um neurônio do modelo, com o mesmo esquema de cores da Figura~\ref {fig:arquitetura-rede} para cada neurônio. Cada aresta representa uma sinapse, representada pela cor do neurônio pré-sináptico. O EC é representado pelo círculo mais externo em preto, é possível ver a organização lamelar do DG com as mGCs e iGCs (vermelho e rosa, respectivamente) e as PCA3s no centro em turquesa. No total, o grafo possui 3.260 nós e 266.596 arestas}{figure.caption.9}{}}
\newlabel{fig:graph@cref}{{[figure][2][]2}{[1][16][]18}{}{}{}}
